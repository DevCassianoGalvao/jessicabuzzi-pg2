Options -Indexes

<FilesMatch "^admin-hash\.txt$">
    Order allow,deny
    Deny from all
</FilesMatch>

RewriteEngine On

# Clean URLs: /admin → admin.html, /avaliacao → avaliacao.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
